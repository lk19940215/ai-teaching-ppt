{
  "version": "2.9",
  "children": [
    {
      "type": "frame",
      "id": "btn-primary",
      "x": 0,
      "y": 0,
      "reusable": true,
      "width": 160,
      "height": 40,
      "fill": "$color.primary",
      "cornerRadius": 8,
      "justifyContent": "center",
      "alignItems": "center",
      "padding": [0, 16],
      "children": [
        {
          "type": "text",
          "id": "btn-primary-label",
          "fill": "#FFFFFF",
          "content": "按钮",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 14,
          "fontWeight": "600"
        }
      ]
    },
    {
      "type": "frame",
      "id": "btn-outline",
      "x": 0,
      "y": 60,
      "reusable": true,
      "width": 120,
      "height": 36,
      "fill": "#FFFFFF",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
      "cornerRadius": 8,
      "justifyContent": "center",
      "alignItems": "center",
      "padding": [0, 12],
      "children": [
        {
          "type": "text",
          "id": "btn-outline-label",
          "fill": "$color.text",
          "content": "按钮",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 14,
          "fontWeight": "500"
        }
      ]
    },
    {
      "type": "frame",
      "id": "btn-success",
      "x": 0,
      "y": 120,
      "reusable": true,
      "width": 200,
      "height": 40,
      "fill": "#16A34A",
      "cornerRadius": 8,
      "justifyContent": "center",
      "alignItems": "center",
      "padding": [0, 16],
      "children": [
        {
          "type": "text",
          "id": "btn-success-label",
          "fill": "#FFFFFF",
          "content": "生成最终 PPT",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 14,
          "fontWeight": "600"
        }
      ]
    },
    {
      "type": "frame",
      "id": "card",
      "x": 0,
      "y": 180,
      "reusable": true,
      "width": 400,
      "height": 200,
      "fill": "$color.bg-card",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
      "cornerRadius": 8,
      "layout": "vertical",
      "gap": 16,
      "padding": 24,
      "children": [
        {
          "type": "text",
          "id": "card-title",
          "fill": "$color.text",
          "content": "卡片标题",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 18,
          "fontWeight": "600"
        },
        {
          "type": "text",
          "id": "card-desc",
          "fill": "$color.text-muted",
          "content": "卡片描述文字占位",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 14,
          "textGrowth": "fixed-width",
          "width": 352
        }
      ]
    },
    {
      "type": "frame",
      "id": "badge",
      "x": 0,
      "y": 400,
      "reusable": true,
      "width": 60,
      "height": 24,
      "fill": "#EEF2FF",
      "cornerRadius": 12,
      "justifyContent": "center",
      "alignItems": "center",
      "children": [
        {
          "type": "text",
          "id": "badge-label",
          "fill": "#4F46E5",
          "content": "标签",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 12,
          "fontWeight": "500"
        }
      ]
    },
    {
      "type": "frame",
      "id": "step-indicator-item",
      "x": 0,
      "y": 440,
      "reusable": true,
      "width": 120,
      "height": 32,
      "gap": 8,
      "alignItems": "center",
      "children": [
        {
          "type": "frame",
          "id": "step-circle",
          "width": 32,
          "height": 32,
          "fill": "$color.primary",
          "cornerRadius": 16,
          "justifyContent": "center",
          "alignItems": "center",
          "children": [
            {
              "type": "text",
              "id": "step-number",
              "fill": "#FFFFFF",
              "content": "1",
              "fontFamily": "Inter, system-ui, sans-serif",
              "fontSize": 14,
              "fontWeight": "600"
            }
          ]
        },
        {
          "type": "text",
          "id": "step-label",
          "fill": "$color.text",
          "content": "步骤名称",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 14,
          "fontWeight": "500"
        }
      ]
    },
    {
      "type": "frame",
      "id": "upload-area",
      "x": 0,
      "y": 490,
      "reusable": true,
      "width": 320,
      "height": 160,
      "fill": "#FFFFFF",
      "stroke": { "align": "inside", "thickness": 2, "fill": "$color.border" },
      "cornerRadius": 8,
      "layout": "vertical",
      "gap": 12,
      "padding": 24,
      "alignItems": "center",
      "justifyContent": "center",
      "children": [
        {
          "type": "frame",
          "id": "upload-icon",
          "width": 48,
          "height": 48,
          "fill": "#F3F4F6",
          "cornerRadius": 24,
          "justifyContent": "center",
          "alignItems": "center",
          "children": [
            {
              "type": "text",
              "id": "upload-icon-symbol",
              "fill": "#9CA3AF",
              "content": "⬆",
              "fontFamily": "Inter, system-ui, sans-serif",
              "fontSize": 24
            }
          ]
        },
        {
          "type": "text",
          "id": "upload-label",
          "fill": "$color.text",
          "content": "上传标题",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 14,
          "fontWeight": "500"
        },
        {
          "type": "text",
          "id": "upload-desc",
          "fill": "$color.text-muted",
          "content": "上传描述",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 12,
          "textGrowth": "fixed-width",
          "width": 280
        }
      ]
    },
    {
      "type": "frame",
      "id": "slide-thumbnail",
      "x": 0,
      "y": 670,
      "reusable": true,
      "width": 160,
      "height": 120,
      "fill": "#FFFFFF",
      "stroke": { "align": "inside", "thickness": 2, "fill": "$color.border" },
      "cornerRadius": 8,
      "layout": "vertical",
      "children": [
        {
          "type": "frame",
          "id": "thumbnail-preview",
          "width": "fill_container",
          "height": 90,
          "fill": "#F9FAFB",
          "cornerRadius": [8, 8, 0, 0]
        },
        {
          "type": "frame",
          "id": "thumbnail-info",
          "width": "fill_container",
          "padding": [6, 8],
          "justifyContent": "space_between",
          "alignItems": "center",
          "children": [
            {
              "type": "text",
              "id": "thumbnail-title",
              "fill": "$color.text",
              "content": "第 1 页",
              "fontFamily": "Inter, system-ui, sans-serif",
              "fontSize": 12,
              "fontWeight": "500"
            },
            {
              "type": "frame",
              "id": "thumbnail-badge",
              "width": 32,
              "height": 16,
              "fill": "#DBEAFE",
              "cornerRadius": 8,
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "thumbnail-badge-text",
                  "fill": "#1D4ED8",
                  "content": "A",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 10,
                  "fontWeight": "500"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "frame",
      "id": "panel-section",
      "x": 0,
      "y": 810,
      "reusable": true,
      "width": 400,
      "height": 200,
      "fill": "#FFFFFF",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
      "cornerRadius": 8,
      "layout": "vertical",
      "children": [
        {
          "type": "frame",
          "id": "panel-header",
          "width": "fill_container",
          "height": 40,
          "fill": "#F9FAFB",
          "cornerRadius": [8, 8, 0, 0],
          "padding": [0, 12],
          "justifyContent": "space_between",
          "alignItems": "center",
          "children": [
            {
              "type": "text",
              "id": "panel-title",
              "fill": "$color.text",
              "content": "面板标题",
              "fontFamily": "Inter, system-ui, sans-serif",
              "fontSize": 14,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "panel-subtitle",
              "fill": "$color.text-muted",
              "content": "副标题",
              "fontFamily": "Inter, system-ui, sans-serif",
              "fontSize": 12
            }
          ]
        },
        {
          "type": "frame",
          "id": "panel-content",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 8,
          "padding": 12,
          "children": [
            {
              "type": "text",
              "id": "panel-content-placeholder",
              "fill": "$color.text-muted",
              "content": "面板内容占位",
              "fontFamily": "Inter, system-ui, sans-serif",
              "fontSize": 14
            }
          ]
        }
      ]
    }
  ],
  "themes": { "mode": ["light"] },
  "variables": {
    "color.primary": { "type": "color", "value": "#4F46E5" },
    "color.bg": { "type": "color", "value": "#F9FAFB" },
    "color.bg-card": { "type": "color", "value": "#FFFFFF" },
    "color.text": { "type": "color", "value": "#111827" },
    "color.text-muted": { "type": "color", "value": "#6B7280" },
    "color.border": { "type": "color", "value": "#E5E7EB" },
    "color.success": { "type": "color", "value": "#16A34A" },
    "color.error": { "type": "color", "value": "#DC2626" },
    "color.warning": { "type": "color", "value": "#F59E0B" },
    "spacing.sm": { "type": "number", "value": 8 },
    "spacing.md": { "type": "number", "value": 16 },
    "spacing.lg": { "type": "number", "value": 24 },
    "spacing.xl": { "type": "number", "value": 32 },
    "radius.md": { "type": "number", "value": 8 },
    "radius.lg": { "type": "number", "value": 12 },
    "font.primary": { "type": "string", "value": "Inter, system-ui, sans-serif" }
  }
}
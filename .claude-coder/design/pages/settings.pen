{
  "version": "2.9",
  "imports": {
    "sys": "../system.lib.pen"
  },
  "children": [
    {
      "type": "frame",
      "id": "page-root",
      "x": 0,
      "y": 0,
      "width": 1440,
      "fill": "$sys:color.bg",
      "layout": "vertical",
      "children": [
        {
          "type": "ref",
          "id": "section-header",
          "ref": "sys:header"
        },
        {
          "type": "frame",
          "id": "section-title",
          "width": "fill_container",
          "padding": [48, 80, 32, 80],
          "children": [
            {
              "type": "text",
              "id": "page-title",
              "fill": "$sys:color.text",
              "content": "设置",
              "fontFamily": "Inter, system-ui, sans-serif",
              "fontSize": 30,
              "fontWeight": "700"
            }
          ]
        },
        {
          "type": "frame",
          "id": "section-main",
          "width": "fill_container",
          "padding": [0, 80, 48, 80],
          "gap": 24,
          "children": [
            {
              "type": "frame",
              "id": "providers-panel",
              "layout": "vertical",
              "width": 320,
              "fill": "$sys:color.bg-card",
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$sys:color.border"
              },
              "cornerRadius": 16,
              "padding": 24,
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "providers-title",
                  "fill": "$sys:color.text",
                  "content": "已配置的服务商",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 18,
                  "fontWeight": "600"
                },
                {
                  "type": "ref",
                  "id": "provider-deepseek",
                  "ref": "sys:provider-item",
                  "descendants": {
                    "provider-name": {
                      "content": "DeepSeek"
                    },
                    "provider-key": {
                      "content": "sk-****abc123"
                    }
                  }
                },
                {
                  "type": "ref",
                  "id": "provider-openai",
                  "ref": "sys:provider-item",
                  "descendants": {
                    "provider-name": {
                      "content": "OpenAI"
                    },
                    "provider-key": {
                      "content": "sk-****xyz789"
                    },
                    "provider-badge": {
                      "opacity": 0
                    }
                  }
                },
                {
                  "type": "text",
                  "id": "providers-empty",
                  "fill": "$sys:color.text-muted",
                  "content": "暂无已配置的服务商",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 14
                }
              ]
            },
            {
              "type": "frame",
              "id": "config-panel",
              "layout": "vertical",
              "width": "fill_container",
              "fill": "$sys:color.bg-card",
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$sys:color.border"
              },
              "cornerRadius": 16,
              "padding": 32,
              "gap": 24,
              "children": [
                {
                  "type": "text",
                  "id": "config-title",
                  "fill": "$sys:color.text",
                  "content": "LLM 服务商配置",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 20,
                  "fontWeight": "600"
                },
                {
                  "type": "frame",
                  "id": "form-fields",
                  "layout": "vertical",
                  "width": "fill_container",
                  "gap": 20,
                  "children": [
                    {
                      "type": "frame",
                      "id": "field-provider",
                      "layout": "vertical",
                      "width": "fill_container",
                      "gap": 8,
                      "children": [
                        {
                          "type": "text",
                          "id": "label-provider",
                          "fill": "$sys:color.text",
                          "content": "服务商",
                          "fontFamily": "Inter, system-ui, sans-serif",
                          "fontSize": 14,
                          "fontWeight": "500"
                        },
                        {
                          "type": "ref",
                          "id": "select-provider",
                          "ref": "sys:select-field",
                          "descendants": {
                            "select-value": {
                              "content": "DeepSeek ✓"
                            }
                          }
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "field-apikey",
                      "layout": "vertical",
                      "width": "fill_container",
                      "gap": 8,
                      "children": [
                        {
                          "type": "text",
                          "id": "label-apikey",
                          "fill": "$sys:color.text",
                          "content": "API Key",
                          "fontFamily": "Inter, system-ui, sans-serif",
                          "fontSize": 14,
                          "fontWeight": "500"
                        },
                        {
                          "type": "ref",
                          "id": "input-apikey",
                          "ref": "sys:input-field",
                          "descendants": {
                            "input-placeholder": {
                              "content": "请输入 API Key"
                            }
                          }
                        },
                        {
                          "type": "text",
                          "id": "hint-apikey",
                          "fill": "$sys:color.text-muted",
                          "content": "您的 API Key 将加密存储在服务器数据库中。",
                          "fontFamily": "Inter, system-ui, sans-serif",
                          "fontSize": 13
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "field-baseurl",
                      "layout": "vertical",
                      "width": "fill_container",
                      "gap": 8,
                      "children": [
                        {
                          "type": "text",
                          "id": "label-baseurl",
                          "fill": "$sys:color.text",
                          "content": "API Base URL（可选）",
                          "fontFamily": "Inter, system-ui, sans-serif",
                          "fontSize": 14,
                          "fontWeight": "500"
                        },
                        {
                          "type": "ref",
                          "id": "input-baseurl",
                          "ref": "sys:input-field",
                          "descendants": {
                            "input-placeholder": {
                              "content": "https://api.deepseek.com"
                            }
                          }
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "field-model",
                      "layout": "vertical",
                      "width": "fill_container",
                      "gap": 8,
                      "children": [
                        {
                          "type": "text",
                          "id": "label-model",
                          "fill": "$sys:color.text",
                          "content": "模型名称（可选）",
                          "fontFamily": "Inter, system-ui, sans-serif",
                          "fontSize": 14,
                          "fontWeight": "500"
                        },
                        {
                          "type": "ref",
                          "id": "input-model",
                          "ref": "sys:input-field",
                          "descendants": {
                            "input-placeholder": {
                              "content": "deepseek-chat"
                            }
                          }
                        }
                      ]
                    },
                    {
                      "type": "rectangle",
                      "id": "divider",
                      "width": "fill_container",
                      "height": 1,
                      "fill": "$sys:color.border"
                    },
                    {
                      "type": "frame",
                      "id": "advanced-section",
                      "layout": "vertical",
                      "width": "fill_container",
                      "gap": 16,
                      "children": [
                        {
                          "type": "text",
                          "id": "advanced-title",
                          "fill": "$sys:color.text",
                          "content": "高级 LLM 参数配置",
                          "fontFamily": "Inter, system-ui, sans-serif",
                          "fontSize": 14,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "field-temperature",
                          "layout": "vertical",
                          "width": "fill_container",
                          "gap": 8,
                          "children": [
                            {
                              "type": "text",
                              "id": "label-temperature",
                              "fill": "$sys:color.text",
                              "content": "温度（Temperature）: 0.7",
                              "fontFamily": "Inter, system-ui, sans-serif",
                              "fontSize": 14,
                              "fontWeight": "500"
                            },
                            {
                              "type": "ref",
                              "id": "slider-temperature",
                              "ref": "sys:slider-track"
                            },
                            {
                              "type": "frame",
                              "id": "slider-labels",
                              "width": "fill_container",
                              "justifyContent": "space_between",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "label-low",
                                  "fill": "$sys:color.text-muted",
                                  "content": "0（确定）",
                                  "fontFamily": "Inter, system-ui, sans-serif",
                                  "fontSize": 12
                                },
                                {
                                  "type": "text",
                                  "id": "label-mid",
                                  "fill": "$sys:color.text-muted",
                                  "content": "1（平衡）",
                                  "fontFamily": "Inter, system-ui, sans-serif",
                                  "fontSize": 12
                                },
                                {
                                  "type": "text",
                                  "id": "label-high",
                                  "fill": "$sys:color.text-muted",
                                  "content": "2（随机）",
                                  "fontFamily": "Inter, system-ui, sans-serif",
                                  "fontSize": 12
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "hint-temperature",
                              "fill": "$sys:color.text-muted",
                              "content": "温度越低输出越确定，越高越有创造力。建议值：0.5-0.8",
                              "fontFamily": "Inter, system-ui, sans-serif",
                              "fontSize": 13
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "token-fields",
                          "width": "fill_container",
                          "gap": 24,
                          "children": [
                            {
                              "type": "frame",
                              "id": "field-input-tokens",
                              "layout": "vertical",
                              "width": "fill_container",
                              "gap": 8,
                              "children": [
                                {
                                  "type": "text",
                                  "id": "label-input-tokens",
                                  "fill": "$sys:color.text",
                                  "content": "最大输入 Token 数",
                                  "fontFamily": "Inter, system-ui, sans-serif",
                                  "fontSize": 14,
                                  "fontWeight": "500"
                                },
                                {
                                  "type": "ref",
                                  "id": "input-input-tokens",
                                  "ref": "sys:input-field",
                                  "descendants": {
                                    "input-placeholder": {
                                      "content": "8000"
                                    }
                                  }
                                },
                                {
                                  "type": "text",
                                  "id": "hint-input-tokens",
                                  "fill": "$sys:color.text-muted",
                                  "content": "限制发送给 LLM 的最大输入 token 数（提示词 + 历史消息）",
                                  "fontFamily": "Inter, system-ui, sans-serif",
                                  "fontSize": 13,
                                  "textGrowth": "fixed-width",
                                  "width": 360
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "field-output-tokens",
                              "layout": "vertical",
                              "width": "fill_container",
                              "gap": 8,
                              "children": [
                                {
                                  "type": "text",
                                  "id": "label-output-tokens",
                                  "fill": "$sys:color.text",
                                  "content": "最大输出 Token 数",
                                  "fontFamily": "Inter, system-ui, sans-serif",
                                  "fontSize": 14,
                                  "fontWeight": "500"
                                },
                                {
                                  "type": "ref",
                                  "id": "input-output-tokens",
                                  "ref": "sys:input-field",
                                  "descendants": {
                                    "input-placeholder": {
                                      "content": "4000"
                                    }
                                  }
                                },
                                {
                                  "type": "text",
                                  "id": "hint-output-tokens",
                                  "fill": "$sys:color.text-muted",
                                  "content": "限制 LLM 返回的最大 token 数，较大的值可能生成更长的响应",
                                  "fontFamily": "Inter, system-ui, sans-serif",
                                  "fontSize": 13,
                                  "textGrowth": "fixed-width",
                                  "width": 360
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "button-group",
                      "width": "fill_container",
                      "gap": 16,
                      "padding": [8, 0, 0, 0],
                      "children": [
                        {
                          "type": "ref",
                          "id": "btn-save",
                          "ref": "sys:btn-primary",
                          "descendants": {
                            "btn-primary-label": {
                              "content": "保存配置"
                            }
                          }
                        },
                        {
                          "type": "ref",
                          "id": "btn-test",
                          "ref": "sys:btn-secondary",
                          "descendants": {
                            "btn-secondary-label": {
                              "content": "测试连接"
                            }
                          }
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "result-success",
                      "layout": "vertical",
                      "width": "fill_container",
                      "fill": "#DCFCE7",
                      "cornerRadius": 8,
                      "padding": 16,
                      "children": [
                        {
                          "type": "text",
                          "id": "result-success-text",
                          "fill": "#15803D",
                          "content": "配置保存成功",
                          "fontFamily": "Inter, system-ui, sans-serif",
                          "fontSize": 14
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "section-about",
          "width": "fill_container",
          "padding": [0, 80, 48, 80],
          "children": [
            {
              "type": "frame",
              "id": "about-panel",
              "layout": "vertical",
              "width": "fill_container",
              "fill": "$sys:color.bg-card",
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$sys:color.border"
              },
              "cornerRadius": 16,
              "padding": 32,
              "gap": 12,
              "children": [
                {
                  "type": "text",
                  "id": "about-title",
                  "fill": "$sys:color.text",
                  "content": "关于",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 20,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "about-desc-1",
                  "fill": "$sys:color.text-muted",
                  "content": "AI 教学 PPT 生成器使用 LLM 服务来生成教学内容。您可以配置自己的 API Key 来使用支持的 LLM 服务商。",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 14,
                  "textGrowth": "fixed-width",
                  "width": 1200
                },
                {
                  "type": "text",
                  "id": "about-desc-2",
                  "fill": "$sys:color.text-muted",
                  "content": "支持的服务商：DeepSeek、OpenAI、Claude、智谱 GLM",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 14
                },
                {
                  "type": "text",
                  "id": "about-desc-3",
                  "fill": "$sys:color.text-muted",
                  "content": "配置保存后会在所有页面中使用，无需重复配置。",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 13
                }
              ]
            }
          ]
        },
        {
          "type": "ref",
          "id": "section-footer",
          "ref": "sys:footer"
        }
      ]
    }
  ]
}
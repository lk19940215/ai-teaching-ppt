{
  "version": "2.9",
  "imports": {
    "sys": "../system.lib.pen"
  },
  "children": [
    {
      "type": "frame",
      "id": "page-root",
      "x": 0,
      "y": 0,
      "width": 1440,
      "fill": "$sys:color.bg",
      "layout": "vertical",
      "children": [
        {
          "type": "ref",
          "id": "section-header",
          "ref": "sys:header"
        },
        {
          "type": "frame",
          "id": "section-hero",
          "width": "fill_container",
          "layout": "vertical",
          "alignItems": "center",
          "padding": [48, 0],
          "gap": 32,
          "children": [
            {
              "type": "text",
              "id": "hero-title",
              "fill": "$sys:color.text",
              "content": "欢迎使用 AI 教学 PPT 生成器",
              "fontFamily": "Inter, system-ui, sans-serif",
              "fontSize": 36,
              "fontWeight": "700",
              "textAlign": "center"
            },
            {
              "type": "text",
              "id": "hero-desc",
              "fill": "$sys:color.text-muted",
              "content": "教师上传教材内容（拍照 / PDF / 文字），AI 自动生成互动性强、美观的教学 PPT。支持年级自适应、英语学科增强，生成的 .pptx 文件兼容 WPS Office。",
              "fontFamily": "Inter, system-ui, sans-serif",
              "fontSize": 18,
              "textAlign": "center",
              "textGrowth": "fixed-width",
              "width": 672
            }
          ]
        },
        {
          "type": "frame",
          "id": "section-steps",
          "width": "fill_container",
          "layout": "vertical",
          "alignItems": "center",
          "padding": [48, 0],
          "gap": 48,
          "children": [
            {
              "type": "frame",
              "id": "steps-cards-row",
              "width": 1280,
              "gap": 32,
              "justifyContent": "center",
              "children": [
                {
                  "type": "ref",
                  "id": "step-card-1",
                  "ref": "sys:step-card",
                  "descendants": {
                    "card-number": {
                      "content": "1"
                    },
                    "card-title": {
                      "content": "上传教材内容"
                    },
                    "card-desc": {
                      "content": "支持拍照图片（OCR 识别）、PDF 电子书、直接粘贴文字三种方式输入教材内容。"
                    }
                  }
                },
                {
                  "type": "ref",
                  "id": "step-card-2",
                  "ref": "sys:step-card",
                  "descendants": {
                    "card-number": {
                      "content": "2"
                    },
                    "card-title": {
                      "content": "选择教学参数"
                    },
                    "card-desc": {
                      "content": "选择年级、学科、PPT 风格和页数，AI 根据参数智能调整内容深度和表达方式。"
                    }
                  }
                },
                {
                  "type": "ref",
                  "id": "step-card-3",
                  "ref": "sys:step-card",
                  "descendants": {
                    "card-number": {
                      "content": "3"
                    },
                    "card-title": {
                      "content": "生成并下载 PPT"
                    },
                    "card-desc": {
                      "content": "一键生成标准 .pptx 文件，可预览每页内容，下载后使用 WPS Office 直接编辑。"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "section-cta",
          "width": "fill_container",
          "layout": "vertical",
          "alignItems": "center",
          "padding": [48, 0],
          "gap": 16,
          "children": [
            {
              "type": "ref",
              "id": "cta-button",
              "ref": "sys:btn-primary",
              "descendants": {
                "btn-primary-label": {
                  "content": "开始使用"
                }
              }
            },
            {
              "type": "text",
              "id": "cta-version",
              "fill": "$sys:color.text-muted",
              "content": "当前版本：开发中",
              "fontFamily": "Inter, system-ui, sans-serif",
              "fontSize": 14
            }
          ]
        },
        {
          "type": "ref",
          "id": "section-footer",
          "ref": "sys:footer"
        }
      ]
    }
  ]
}